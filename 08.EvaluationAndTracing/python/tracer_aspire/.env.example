# Azure AI Foundry Configuration
FOUNDRY_PROJECT_ENDPOINT="your-azure-ai-project-endpoint"
FOUNDRY_MODEL="gpt-4o-mini"

# OpenTelemetry Configuration
# Enable instrumentation to collect telemetry
ENABLE_INSTRUMENTATION=true

# OTLP Endpoint for telemetry export (e.g., Aspire Dashboard)
# For Aspire Dashboard running locally with Docker:
# docker run --rm -it -d -p 18888:18888 -p 4317:18889 --name aspire-dashboard mcr.microsoft.com/dotnet/aspire-dashboard:latest
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional: Service name for your application
# OTEL_SERVICE_NAME=weather-agent

# Optional: Enable console exporters for debugging (prints telemetry to console)
# ENABLE_CONSOLE_EXPORTERS=true

# Optional: Enable sensitive data in telemetry (prompts, responses)
# WARNING: Only use in development/testing, not in production
# ENABLE_SENSITIVE_DATA=true
